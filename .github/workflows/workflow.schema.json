{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow.schema.json",
  "title": "Workflow",
  "type": "object",
  "required": ["id", "name", "version", "category", "status", "trigger", "objective", "steps", "outputs"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^WF-[A-Z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "default": "v1.0"
    },
    "owner": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": ["build", "data", "marketing", "content", "seo", "analytics", "launch", "validation", "ops", "experiment"]
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "paused", "deprecated"]
    },
    "trigger": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "properties": {
        "in_scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/io_item" }
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/io_item" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "decision_logic": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision" }
    },
    "failure_handling": {
      "type": "array",
      "items": { "$ref": "#/$defs/failure_rule" }
    },
    "automation_opportunities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deliverables": {
      "type": "array",
      "items": { "type": "string" }
    },
    "kpis": {
      "type": "array",
      "items": { "$ref": "#/$defs/kpi" }
    },
    "tracking": {
      "$ref": "#/$defs/tracking"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "io_item": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "required": { "type": "boolean", "default": true },
        "description": { "type": "string" }
      }
    },
    "step": {
      "type": "object",
      "required": ["id", "name", "action"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^STEP-[0-9]+$"
        },
        "name": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "decision": {
      "type": "object",
      "required": ["condition", "action"],
      "properties": {
        "condition": { "type": "string" },
        "action": { "type": "string" }
      }
    },
    "failure_rule": {
      "type": "object",
      "required": ["scenario", "action"],
      "properties": {
        "scenario": { "type": "string" },
        "action": { "type": "string" }
      }
    },
    "kpi": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "target": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "tracking": {
      "type": "object",
      "properties": {
        "logs_stored_in": { "type": "string" },
        "events_tracked": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
